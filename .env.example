# Copie este arquivo para .env e ajuste as senhas/portas.
# NUNCA commite o .env real no git.

# --- Redis (SESSION) ---
REDIS_SESSIONS_PORT=6379

# AuthService Profile
REDIS_SESSIONS_AUTH_USERNAME=
REDIS_SESSIONS_AUTH_PASSWORD=

# BFF Profile
REDIS_SESSIONS_BFF_USERNAME=
REDIS_SESSIONS_BFF_PASSWORD=


# --- Redis ---

REDIS_CACHE_PORT=6380
REDIS_CACHE_PASSWORD=

REDIS_FEED_PORT=6381
REDIS_FEED_PASSWORD=


# --- Postgres ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=
