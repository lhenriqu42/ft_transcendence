# --- Kafka ---
KAFKA_EXTERNAL_PORT=9094
KAFKA_UI_PORT=8089

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Observabilidade ---
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
